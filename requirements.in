# DoML top-level dependencies (unpinned)
# Regenerate requirements.txt with:
#   docker compose run --rm jupyter pip-compile requirements.in
#
# Do NOT edit requirements.txt by hand — it is generated from this file.

# --- Core DB / notebook tooling ---
duckdb
papermill
# nbconvert and nbformat are provided by the conda base image (quay.io/jupyter/datascience-notebook)
# Do NOT pip-install nbconvert — it conflicts with the conda-managed version
jinja2
# mistune 3.x breaks the conda-managed nbconvert — pin to 2.x
mistune<3

# --- Reproducibility ---
nbstripout
pre-commit
pip-tools
pytest

# --- ML stack ---
shap
optuna
umap-learn
xgboost
lightgbm
statsmodels
prophet

# --- Visualization / profiling ---
plotly

# --- Data acquisition ---
# Note: after adding kaggle here, regenerate requirements.txt with:
#   docker compose run --rm jupyter pip-compile requirements.in
# Then rebuild the image: docker compose build
kaggle
